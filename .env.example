# Local-only environment overrides (do not commit real secrets here).
#
# Usage:
#   cp .env.example .env
#   # then edit .env to match your project
#
# Optional but recommended: set a unique name per copy of this template.
# This controls the Docker Compose project name and is also used to build the explicit dev container name.
COMPOSE_PROJECT_NAME=my-project

# Optional: override which host serial device is mounted into the container.
# SERIAL_DEVICE=/dev/ttyACM0
